{
  "name": "pluff",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:mcp": "pnpm --filter @pluff/mcp dev",
    "dev:postgres": "docker compose up -d postgres",
    "dev:relay": "pnpm --filter @pluff/relay dev",
    "dev:web": "pnpm --filter @pluff/web dev",
    "stop:postgres": "docker compose stop postgres",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  }
}
